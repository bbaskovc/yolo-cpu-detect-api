# Example configuration only. Do not commit a real secret to .env.

# Required at runtime once the API is implemented.
YOLO_API_KEY=replace-with-a-long-random-server-side-secret

# Public model contract.
YOLO_MODEL_ID=yolo-cpu-detect-v1
YOLO_MODEL_PATH=/opt/yolo/models/yolo-cpu-detect-v1.onnx
YOLO_LABELS_PATH=/opt/yolo/models/yolo-cpu-detect-v1.labels.json
YOLO_MODEL_SHA256=replace-with-approved-model-sha256

# CPU behavior. Final values require benchmark evidence on the target machine.
YOLO_CPU_THREADS=1
MAX_CONCURRENT_INFERENCES=1

# Request limits. Treat these as baseline defaults pending benchmark/security validation.
MAX_REQUEST_BYTES=12582912
MAX_IMAGE_BYTES=8388608
MAX_IMAGE_PIXELS=16000000
MAX_IMAGE_SIDE_PX=8192

# Detection defaults. Model-specific calibration is a later decision gate.
YOLO_CONFIDENCE_THRESHOLD=0.35
YOLO_IOU_THRESHOLD=0.45

# Operational configuration.
LOG_LEVEL=INFO
